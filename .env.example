# Supabase — get these from your project Settings → API
VITE_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
VITE_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key

# Supabase (server-side) — get these from your project Settings → API
# The service role key bypasses RLS — never expose it to the client
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for OAuth tokens and API keys stored in Supabase
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string

# Get your Notion API key from https://www.notion.so/my-integrations
# Create an integration, then share your databases with it
# This is used as a global fallback if OAuth is not configured or user hasn't connected
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion OAuth — create a *public* integration at https://www.notion.so/my-integrations
# Set the integration type to "Public" and configure the redirect URI below
# NOTION_OAUTH_CLIENT_ID=your-notion-oauth-client-id
# NOTION_OAUTH_CLIENT_SECRET=your-notion-oauth-client-secret
# Must exactly match what you set in Notion integration settings
# NOTION_REDIRECT_URI=http://localhost:3001/api/notion/callback

# Optional: default Notion page where AI-created databases will be placed.
# You can also set this once via the MCP tool: set_notion_workspace_page
# To find a page ID: open the page in Notion → Share → Copy link → grab the ID at the end of the URL
# NOTION_PARENT_PAGE_ID=

# YouTube Data API v3 — required for voice "play a video about X" commands
# Get from https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# Anthropic API key — required for voice command execution
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Bing Search — required for Walli web search ("what's the score", "show me X", etc.)
# Create a "Bing Search v7" resource at portal.azure.com → free tier: 3 calls/sec, 1000/month
BING_SEARCH_API_KEY=

# ElevenLabs — required for voice TTS responses (falls back to browser TTS if not set)
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
# Optional: override the default voice (Rachel). Find voice IDs at elevenlabs.io/voice-lab
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Server port (optional, defaults to 3001)
PORT=3001

# ntfy push notifications — get the free app at ntfy.sh
# Pick any unique topic name (it's like a private channel — keep it secret)
# NTFY_TOPIC=my-walli-abc123
# Optional: self-hosted ntfy server
# NTFY_SERVER=https://ntfy.sh

# Google Calendar OAuth — create credentials at console.cloud.google.com
# OAuth 2.0 Client ID → Web application → add the redirect URI below as an authorized redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must exactly match what you set in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gcal/callback

# Todoist OAuth — create app at https://developer.todoist.com/appconsole.html
# Set OAuth redirect URL to: http://localhost:3001/api/todoist/callback
TODOIST_CLIENT_ID=your-todoist-client-id
TODOIST_CLIENT_SECRET=your-todoist-client-secret

# Spotify Now Playing widget
# 1. Go to https://developer.spotify.com/dashboard → Create an app
# 2. Add redirect URI: http://localhost:3001/api/spotify/callback
# 3. Copy Client ID and Client Secret below
# Spotify — no env vars needed. Configure via the widget settings panel in the app.
