# Get your Notion API key from https://www.notion.so/my-integrations
# Create an integration, then share your databases with it
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (optional, defaults to 3001)
PORT=3001

# Google Calendar OAuth credentials
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3001/api/gcal/callback
# 4. Enable Google Calendar API in the API Library
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
