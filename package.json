{
  "name": "smart-whiteboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "NODE_ENV=production tsx server/index.ts",
    "mcp": "tsx mcp/server.ts",
    "start:kiosk": "concurrently \"npm run server\" \"npm run client\" \"node scripts/kiosk.js\"",
    "client": "vite --host",
    "server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --config-dir packages/ui-kit/.storybook",
    "build-storybook": "storybook build --config-dir packages/ui-kit/.storybook",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:client": "vitest run --project client",
    "test:server": "vitest run --project server"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@notionhq/client": "^2.2.15",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.51.1",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.4.1",
    "recharts": "^3.8.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.2.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "jsdom": "^29.0.2",
    "msw": "^2.13.2",
    "postcss": "^8.4.38",
    "prettier": "^3.3.3",
    "storybook": "^10.2.16",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
